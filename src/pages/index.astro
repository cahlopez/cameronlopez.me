---
import Layout from "../layouts/Layout.astro";
import Experience from "../components/Experience.astro";
import Project from "../components/Project.astro";

import usefilmPicker from "../assets/usefilmpicker.png";
import teslaToolbox from "../assets/tesla-toolbox.png";
import gallry from "../assets/gallry.png";
---

<Layout>
  <main class="mx-auto max-w-2xl px-6">
    <!-- INTRO -->
    <section class="reveal pt-20 pb-8 sm:pt-28">
      <h1
        class="text-primary text-3xl font-semibold tracking-tight sm:text-4xl"
      >
        Cameron Lopez
      </h1>
      <p class="text-secondary mt-2 text-lg">Full-stack Developer</p>
      <p class="text-muted mt-6 leading-relaxed">
        I build user-friendly apps using modern JavaScript technologies. I'm
        passionate about web design and programming, leveraging my skills to
        create things that improve the quality of life for myself and others.
        Outside of that, running is a big part of my life, and I also enjoy
        reading and snowboarding. I'm currently working at Tesla as an
        Engineering Technician.
      </p>
    </section>

    <!-- EXPERIENCE -->
    <section class="reveal pt-16">
      <h2 class="text-muted mb-8 font-mono text-xs tracking-widest uppercase">
        Experience
      </h2>
      <div>
        <Experience
          title="Engineering Technician II"
          company="Tesla"
          timeline="Jul 2024 — Present"
          items={[
            "Developed interactive dashboards to visualize data from MySQL, tracking KPIs, managing headcount, and monitoring production line downtime",
            "Created an internal all-in-one training website to streamline tracking, scheduling, and sign-up processes, using TypeScript, Remix, TailwindCSS, Drizzle, Git, and Node.js",
            'Developed a "toolbox" website enabling efficient use of internal Tesla APIs for technician operations, using React Router, TypeScript, TailwindCSS, Git, and Node.js',
          ]}
        />
        <Experience
          title="Engineering Technician"
          company="Tesla"
          timeline="Aug 2023 — Jul 2024"
          items={[
            "Developed a Microsoft Teams bot to automate the tracking of daily technician tasks and resource allocation, utilizing Git, MySQL, TypeScript, Microsoft Bot Framework SDK, and Node.js",
            "Deployed internal serverless applications using Docker and Kubernetes for scalable, efficient hosting",
            "Managed project progress and tracked work hours through Jira tickets, ensuring alignment with deadlines and objectives",
          ]}
        />
      </div>
    </section>

    <!-- PROJECTS -->
    <section id="projects" class="reveal scroll-mt-20 pt-16">
      <h2 class="text-muted mb-8 font-mono text-xs tracking-widest uppercase">
        Selected Work
      </h2>
      <div>
        <Project
          title="Gallry"
          link="https://gallry.space"
          image={{ location: gallry, alt: "Gallry" }}
          description="A photo-gallery platform for photographers to deliver client galleries through a single link — no client accounts, just a branded portfolio with custom domains, watermarks, and storage that scales."
          tags={["TypeScript", "Remix", "Postgres", "R2", "Node.js"]}
        />
        <Project
          title="Tesla Toolbox"
          link="https://github.com/cahlopez/tesla-toolbox"
          image={{ location: teslaToolbox, alt: "Tesla Toolbox" }}
          description="A website built for internal Tesla use, helping technicians easily utilize Tesla's internal factory APIs and streamline their workflow."
          tags={["TypeScript", "React", "TailwindCSS", "Next.js"]}
        />
      </div>
    </section>

    <!-- CONTACT -->
    <section class="reveal pt-16">
      <h2 class="text-muted mb-4 font-mono text-xs tracking-widest uppercase">
        Contact
      </h2>
      <p class="text-secondary leading-relaxed">
        I'd love to work with you. Reach out at{" "}
        <a
          href="mailto:hello@cameronlopez.me"
          class="text-primary decoration-muted hover:decoration-accent underline underline-offset-4 transition-colors"
        >
          hello@cameronlopez.me
        </a>
        .
      </p>
    </section>
  </main>
</Layout>
